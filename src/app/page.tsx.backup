"use client";

import { useState, useEffect } from "react";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Separator } from "@/components/ui/separator";
import { Sheet, SheetContent, SheetHeader, SheetTitle, SheetTrigger } from "@/components/ui/sheet";
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogTrigger, DialogFooter, DialogClose } from "@/components/ui/dialog";
import { Input } from "@/components/ui/input";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { ScrollArea } from "@/components/ui/scroll-area";
import { Textarea } from "@/components/ui/textarea";
import { Label } from "@/components/ui/label";
import { Checkbox } from "@/components/ui/checkbox";
import { Dish, DishCategory, CartItem, CATEGORY_NAMES, CATEGORY_COLORS, TASTE_TAGS, DEFAULT_AVOIDANCE_TAGS, AvoidanceTag } from "@/lib/types";
import { sampleDishes, DEFAULT_TABLES, DEFAULT_PEOPLE } from "@/lib/data";
import { saveDishes, loadDishes, saveOrder, shouldBackup, updateBackupDate, exportData, savePrinterIP, getPrinterIP, saveAvoidanceTags, getAvoidanceTags, getAvoidanceTagsByCategory, saveAvoidanceTagsByCategory } from "@/lib/storage";
import { ShoppingCart, Plus, Minus, Trash2, Printer, Users, Table, Upload, Camera, X, Check, Edit, Download, AlertCircle, Settings, Eye, Image as ImageIcon, ChevronLeft, ChevronRight, Maximize2, Minimize2, Printer as PrinterIcon } from "lucide-react";
import Image from "next/image";

export default function Home() {
  const [selectedCategory, setSelectedCategory] = useState<DishCategory>("special");
  const [cart, setCart] = useState<CartItem[]>([]);
  const [tableNumber, setTableNumber] = useState("1号桌");
  const [customerCount, setCustomerCount] = useState("2人");
  const [isCartOpen, setIsCartOpen] = useState(false);
  const [showPrintDialog, setShowPrintDialog] = useState(false);
  const [showUploadDialog, setShowUploadDialog] = useState(false);
  const [dishes, setDishes] = useState<Dish[]>(sampleDishes);
  const [uploadCategory, setUploadCategory] = useState<DishCategory>("special");
  const [uploadImage, setUploadImage] = useState<File | null>(null);
  const [uploadPreview, setUploadPreview] = useState<string>("");
  const [uploadName, setUploadName] = useState("");
  const [uploadPrice, setUploadPrice] = useState("");
  const [currentTime, setCurrentTime] = useState<string>("");

  // 菜品详情编辑相关状态
  const [editDishDialog, setEditDishDialog] = useState(false);
  const [editingDish, setEditingDish] = useState<Dish | null>(null);
  const [editImage, setEditImage] = useState<File | null>(null);
  const [editPreview, setEditPreview] = useState<string>("");
  const [editImages, setEditImages] = useState<string[]>([]); // 多图片编辑
  const [currentImageIndex, setCurrentImageIndex] = useState(0); // 当前显示的图片索引

  // 管理模式
  const [isEditMode, setIsEditMode] = useState(false);

  // 菜品查看详情页
  const [viewDishDialog, setViewDishDialog] = useState(false);
  const [viewingDish, setViewingDish] = useState<Dish | null>(null);

  // 口味选择相关状态
  const [tasteSelections, setTasteSelections] = useState<Record<string, { tags: string[]; custom: string }>>({});

  // 忌口选择相关状态
  const [avoidanceSelections, setAvoidanceSelections] = useState<Record<string, string[]>>({});
  const [showAvoidanceDialog, setShowAvoidanceDialog] = useState(false);
  const [currentAvoidanceDish, setCurrentAvoidanceDish] = useState<Dish | null>(null);

  // 忌口标签管理状态
  const [avoidanceTagsByCategory, setAvoidanceTagsByCategory] = useState<Record<DishCategory, AvoidanceTag[]>>(DEFAULT_AVOIDANCE_TAGS);
  const [showAvoidanceManagement, setShowAvoidanceManagement] = useState(false);
  const [newAvoidanceTagName, setNewAvoidanceTagName] = useState("");
  const [newAvoidanceTagIcon, setNewAvoidanceTagIcon] = useState("");
  const [managingCategory, setManagingCategory] = useState<DishCategory>("special");

  // 备份提示
  const [showBackupAlert, setShowBackupAlert] = useState(false);

  // 打印机相关
  const [printerIP, setPrinterIP] = useState("");
  const [showPrinterSettings, setShowPrinterSettings] = useState(false);

  // 全屏状态
  const [isFullscreen, setIsFullscreen] = useState(false);

  // 初始化：从本地存储加载数据
  useEffect(() => {
    // 加载菜品数据
    const savedDishes = loadDishes();
    if (savedDishes) {
      setDishes(savedDishes);
    }

    // 加载打印机IP
    const savedPrinterIP = getPrinterIP();
    // 如果没有保存的IP，使用默认IP（用户提供的打印机IP）
    setPrinterIP(savedPrinterIP || "192.168.0.113");

    // 加载分类忌口标签
    const savedAvoidanceTagsByCategory = getAvoidanceTagsByCategory();
    setAvoidanceTagsByCategory(savedAvoidanceTagsByCategory);

    // 检查是否需要备份
    if (shouldBackup()) {
      setShowBackupAlert(true);
    }
  }, []);

  // 监听全屏状态变化
  useEffect(() => {
    const handleFullscreenChange = () => {
      setIsFullscreen(!!document.fullscreenElement);
    };

    document.addEventListener('fullscreenchange', handleFullscreenChange);

    // 页面加载后提示用户进入全屏
    const timer = setTimeout(() => {
      if (!document.fullscreenElement) {
        const shouldEnterFullscreen = confirm("是否进入全屏模式以获得最佳点菜体验？");
        if (shouldEnterFullscreen) {
          toggleFullscreen();
        }
      }
    }, 1000);

    return () => {
      document.removeEventListener('fullscreenchange', handleFullscreenChange);
      clearTimeout(timer);
    };
  }, []);

  // 全屏切换函数
  const toggleFullscreen = () => {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch((err) => {
        console.error(`全屏模式启用失败: ${err.message}`);
      });
    } else {
      document.exitFullscreen();
    }
  };

  // 客户端初始化时间
  useEffect(() => {
    setCurrentTime(new Date().toLocaleString());
  }, []);

  // 过滤当前分类的菜品
  const filteredDishes = dishes.filter(dish => dish.category === selectedCategory);

  // 计算购物车总价
  const cartTotal = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
  const cartCount = cart.reduce((sum, item) => sum + item.quantity, 0);

  // 添加到购物车
  const addToCart = (dish: Dish) => {
    setCart(prev => {
      const existing = prev.find(item => item.id === dish.id);
      const tasteInfo = tasteSelections[dish.id] || { tags: [], custom: "" };
      const avoidanceInfo = avoidanceSelections[dish.id] || [];

      if (existing) {
        return prev.map(item =>
          item.id === dish.id ? { ...item, quantity: item.quantity + 1 } : item
        );
      }
      return [
        ...prev,
        {
          ...dish,
          quantity: 1,
          taste: tasteInfo.tags,
          customTaste: tasteInfo.custom,
          avoidance: avoidanceInfo,
        },
      ];
    });
  };

  // 从购物车移除
  const removeFromCart = (dishId: string) => {
    setCart(prev => prev.filter(item => item.id !== dishId));
  };

  // 更新数量
  const updateQuantity = (dishId: string, delta: number) => {
    setCart(prev => {
      const newCart = prev.map(item => {
        if (item.id === dishId) {
          const newQuantity = Math.max(0, item.quantity + delta);  // 允许减少到0
          return { ...item, quantity: newQuantity };
        }
        return item;
      });

      // 过滤掉数量为0的菜品，从购物车中移除
      return newCart.filter(item => item.quantity > 0);
    });
  };

  // 清空购物车
  const clearCart = () => {
    setCart([]);
  };

  // 获取购物车中菜品的数量
  const getCartItemCount = (dishId: string): number => {
    const item = cart.find(item => item.id === dishId);
    return item?.quantity || 0;
  };

  // 点击菜品卡片
  const handleDishClick = (dish: Dish) => {
    if (isEditMode) {
      // 管理模式：打开编辑对话框
      openEditDishDialog(dish);
    } else {
      // 查看模式：打开查看详情对话框
      setViewingDish(dish);
      setCurrentImageIndex(0);
      setViewDishDialog(true);
    }
  };

  // 打开菜品详情编辑对话框
  const openEditDishDialog = (dish: Dish) => {
    setEditingDish({ ...dish });
    setEditPreview(dish.image);
    setEditImages(dish.images || [dish.image]);
    setEditImage(null);
    setCurrentImageIndex(0);
    setEditDishDialog(true);
  };

  // 保存菜品编辑
  const saveDishEdit = () => {
    if (!editingDish) return;

    const updatedDish: Dish = {
      ...editingDish,
      image: editImages[0] || editPreview, // 使用第一张图作为主图
      images: editImages.length > 0 ? editImages : [editPreview],
    };

    const updatedDishes = dishes.map(d =>
      d.id === editingDish.id ? updatedDish : d
    );

    const result = saveDishes(updatedDishes); // 保存到本地存储

    if (result.success) {
      setDishes(updatedDishes);
      setEditDishDialog(false);
      setEditingDish(null);
      setEditImages([]);
    } else {
      alert(result.message || "保存失败，请重试");
    }
  };

  // 添加图片到编辑列表（使用API上传）
  const addImageToEdit = async (file: File) => {
    try {
      const formData = new FormData();
      formData.append("file", file);

      const response = await fetch("/api/upload-image", {
        method: "POST",
        body: formData,
      });

      if (!response.ok) {
        throw new Error("Failed to upload image");
      }

      const result = await response.json();

      if (result.success && result.url) {
        setEditImages(prev => [...prev, result.url]);
        if (editImages.length === 0) {
          setEditPreview(result.url);
        }
      }
    } catch (error) {
      console.error("Error uploading image:", error);
      alert("图片上传失败，请重试");
    }
  };

  // 从编辑列表移除图片
  const removeImageFromEdit = (index: number) => {
    setEditImages(prev => prev.filter((_, i) => i !== index));
  };

  // 处理编辑图片上传
  const handleEditImageChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      addImageToEdit(file);
      addImageToEdit(file);
    }
  };

  // 处理口味标签切换
  const toggleTasteTag = (dishId: string, tag: string) => {
    setTasteSelections(prev => {
      const current = prev[dishId] || { tags: [], custom: "" };
      const newTags = current.tags.includes(tag)
        ? current.tags.filter(t => t !== tag)
        : [...current.tags, tag];

      return {
        ...prev,
        [dishId]: { ...current, tags: newTags },
      };
    });
  };

  // 处理自定义口味输入
  const handleCustomTasteChange = (dishId: string, value: string) => {
    setTasteSelections(prev => {
      const current = prev[dishId] || { tags: [], custom: "" };
      return {
        ...prev,
        [dishId]: { ...current, custom: value },
      };
    });
  };

  // 打开忌口选择对话框
  const openAvoidanceDialog = (dish: Dish) => {
    setCurrentAvoidanceDish(dish);
    setShowAvoidanceDialog(true);
  };

  // 处理忌口标签切换
  const toggleAvoidanceTag = (tag: string) => {
    if (!currentAvoidanceDish) return;

    setAvoidanceSelections(prev => {
      const current = prev[currentAvoidanceDish.id] || [];
      const newTags = current.includes(tag)
        ? current.filter(t => t !== tag)
        : [...current, tag];

      return {
        ...prev,
        [currentAvoidanceDish.id]: newTags,
      };
    });
  };

  // 添加忌口标签
  const handleAddAvoidanceTag = () => {
    if (!newAvoidanceTagName.trim()) return;

    const existingTags = avoidanceTagsByCategory[managingCategory];
    if (existingTags?.some(tag => tag.name === newAvoidanceTagName.trim())) {
      alert("该标签已存在");
      return;
    }

    const newTag: AvoidanceTag = {
      id: `tag-${Date.now()}`,
      name: newAvoidanceTagName.trim(),
      icon: newAvoidanceTagIcon.trim() || undefined
    };

    const updatedTagsByCategory = {
      ...avoidanceTagsByCategory,
      [managingCategory]: [...(existingTags || []), newTag]
    };

    setAvoidanceTagsByCategory(updatedTagsByCategory);
    saveAvoidanceTagsByCategory(updatedTagsByCategory);
    setNewAvoidanceTagName("");
    setNewAvoidanceTagIcon("");
  };

  // 删除忌口标签
  const handleDeleteAvoidanceTag = (tagId: string) => {
    if (!confirm(`确定要删除该标签吗？`)) return;

    const updatedTagsByCategory = {
      ...avoidanceTagsByCategory,
      [managingCategory]: (avoidanceTagsByCategory[managingCategory] || []).filter(tag => tag.id !== tagId)
    };

    setAvoidanceTagsByCategory(updatedTagsByCategory);
    saveAvoidanceTagsByCategory(updatedTagsByCategory);
  };

  // 导出数据备份
  const handleExportBackup = () => {
    const data = exportData();
    const blob = new Blob([data], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `陶然小灶_备份_${new Date().toLocaleDateString()}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    updateBackupDate();
    setShowBackupAlert(false);
  };

  // 优化存储：将Base64图片转换为文件系统存储
  const handleOptimizeStorage = async () => {
    if (!confirm("确定要优化存储吗？这将把所有Base64格式的图片转换为文件系统存储，可以大幅减少浏览器存储空间占用。\n\n此过程可能需要几秒钟，请勿关闭页面。")) {
      return;
    }

    try {
      const response = await fetch("/api/convert-images", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ dishes }),
      });

      const result = await response.json();

      if (result.success) {
        // 更新本地数据
        const result2 = saveDishes(result.dishes);
        if (result2.success) {
          setDishes(result.dishes);
          alert(`优化完成！成功转换 ${result.convertedCount} 张图片。\n\n现在您可以上传更多图片了！`);
        } else {
          alert("优化失败：无法保存转换后的数据");
        }
      } else {
        alert(`优化失败：${result.error}`);
      }
    } catch (error) {
      console.error("优化存储失败:", error);
      alert("优化失败，请重试");
    }
  };

  // 打印订单到WiFi打印机
  const handlePrint = async () => {
    try {
      // 检查打印机IP
      if (!printerIP) {
        alert("请先设置打印机IP地址");
        setShowPrinterSettings(true);
        return;
      }

      // 获取打印内容
      const printContent = document.getElementById("print-content");
      if (!printContent) {
        alert("打印内容为空");
        return;
      }

      // 格式化打印内容为纯文本
      let formattedContent = printContent.innerText;

      // 添加格式化
      const order = {
        id: Date.now().toString(),
        tableNumber,
        customerCount: parseInt(customerCount),
        items: cart,
        totalAmount: cartTotal,
        createdAt: new Date(),
      };

      // 构建打印文本
      let printText = "================================\n";
      printText += "       陶然小灶 - 点菜清单       \n";
      printText += "================================\n\n";
      printText += `桌号: ${tableNumber}\n`;
      printText += `人数: ${customerCount}\n`;
      printText += `时间: ${new Date().toLocaleString()}\n`;
      printText += "--------------------------------\n\n";

      cart.forEach((item) => {
        printText += `${item.name}\n`;
        printText += `  数量: ${item.quantity}  单价: ¥${item.price}\n`;
        if (item.taste && item.taste.length > 0) {
          printText += `  口味: ${item.taste.join(", ")}\n`;
        }
        if (item.avoidance && item.avoidance.length > 0) {
          printText += `  忌口: ${item.avoidance.join(", ")}\n`;
        }
        if (item.customTaste) {
          printText += `  备注: ${item.customTaste}\n`;
        }
        printText += "--------------------------------\n";
      });

      printText += "\n";
      printText += `总计: ¥${cartTotal.toFixed(2)}\n`;
      printText += "================================\n";
      printText += "感谢光临！祝您用餐愉快！\n";
      printText += "================================\n";

      // 发送到打印机
      const response = await fetch("/api/print", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          printContent: printText,
          printerIP: printerIP,
        }),
      });

      const result = await response.json();

      if (result.success) {
        // 保存订单
        saveOrder(order);
        setShowPrintDialog(false);
        clearCart();
        alert("打印成功！");
      } else {
        alert(`打印失败: ${result.message}`);
      }
    } catch (error) {
      console.error("打印错误:", error);
      alert("打印失败，请检查打印机连接");
    }
  };

  // 测试打印功能
  const handleTestPrint = async () => {
    if (!printerIP) {
      alert("请先输入打印机IP地址");
      return;
    }

    // 检测当前是否在云端环境
    const isCloudEnv = window.location.hostname.includes('dev.coze.site');

    if (isCloudEnv) {
      const useSimulate = confirm(
        "⚠️ 检测到当前运行在云端环境\n\n" +
        "云端服务器无法访问您的局域网打印机（" + printerIP + "）。\n\n" +
        "您想要：\n" +
        "【确定】- 模拟打印（测试打印格式，不会实际打印）\n" +
        "【取消】- 尝试实际打印（会连接超时）"
      );

      if (useSimulate) {
        await performSimulatedTestPrint();
        return;
      }
    }

    // 尝试实际打印
    await performActualTestPrint();
  };

  // 执行模拟打印
  const performSimulatedTestPrint = async () => {
    try {
      // 构建测试打印内容
      let printText = "================================\n";
      printText += "          测试打印单\n";
      printText += "================================\n\n";
      printText += `打印机IP: ${printerIP}\n`;
      printText += `测试时间: ${new Date().toLocaleString()}\n`;
      printText += "--------------------------------\n";
      printText += "✓ 打印机连接正常\n";
      printText += "✓ 打印功能正常\n";
      printText += "✓ 陶然小灶系统就绪\n";
      printText += "--------------------------------\n\n";
      printText += "如果您看到这张测试单，说明：\n";
      printText += "1. 打印机连接配置正确\n";
      printText += "2. 网络连接正常\n";
      printText += "3. 打印功能可以使用\n";
      printText += "================================\n\n";
      printText += "打印类型: 测试打印（模拟）\n";
      printText += "================================\n";

      // 发送模拟打印请求
      const response = await fetch("/api/print", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          printContent: printText,
          printerIP: printerIP,
          simulate: true,  // 启用模拟模式
        }),
      });

      const result = await response.json();

      if (result.success) {
        alert(
          "✓ 模拟打印成功！\n\n" +
          "打印内容已生成，格式正确。\n\n" +
          "--- 打印内容预览 ---\n\n" +
          printText +
          "\n--- 预览结束 ---\n\n" +
          "注意：这是模拟打印，实际使用时需要在本地环境才能连接到打印机。"
        );
      } else {
        alert(`✗ 模拟打印失败：${result.message}`);
      }
    } catch (error) {
      console.error("模拟打印错误:", error);
      alert(`✗ 模拟打印失败：${(error as Error).message}`);
    }
  };

  // 执行实际打印
  const performActualTestPrint = async () => {
    try {
      // 构建测试打印内容
      let printText = "================================\n";
      printText += "          测试打印单\n";
      printText += "================================\n\n";
      printText += `打印机IP: ${printerIP}\n`;
      printText += `测试时间: ${new Date().toLocaleString()}\n`;
      printText += "--------------------------------\n";
      printText += "✓ 打印机连接正常\n";
      printText += "✓ 打印功能正常\n";
      printText += "✓ 陶然小灶系统就绪\n";
      printText += "--------------------------------\n\n";
      printText += "如果您看到这张测试单，说明：\n";
      printText += "1. 打印机连接配置正确\n";
      printText += "2. 网络连接正常\n";
      printText += "3. 打印功能可以使用\n";
      printText += "================================\n\n";
      printText += "打印类型: 测试打印\n";
      printText += "================================\n";

      // 发送打印请求
      const response = await fetch("/api/print", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          printContent: printText,
          printerIP: printerIP,
        }),
      });

      const result = await response.json();

      if (result.success) {
        alert("✓ 测试打印成功！\n\n请检查打印机是否已输出测试单。");
      } else {
        alert(`✗ 测试打印失败：${result.message}\n\n请检查：\n1. 打印机IP地址是否正确\n2. 打印机和设备是否在同一WiFi网络\n3. 打印机是否开启并处于待机状态\n4. 是否在本地环境运行（而非云端）`);
      }
    } catch (error) {
      console.error("测试打印错误:", error);
      alert(`✗ 测试打印失败：${(error as Error).message}\n\n请检查网络连接和打印机状态。`);
    }
  };

  // 处理图片上传（上传新菜品时使用）
  const handleImageChange = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      setUploadImage(file);
      try {
        const formData = new FormData();
        formData.append("file", file);

        const response = await fetch("/api/upload-image", {
          method: "POST",
          body: formData,
        });

        if (!response.ok) {
          throw new Error("Failed to upload image");
        }

        const result = await response.json();

        if (result.success && result.url) {
          setUploadPreview(result.url);
        }
      } catch (error) {
        console.error("Error uploading image:", error);
        alert("图片上传失败，请重试");
      }
    }
  };

  // 提交新菜品
  const handleAddDish = () => {
    if (!uploadName || !uploadPrice || !uploadPreview) {
      alert("请填写完整信息");
      return;
    }

    const newDish: Dish = {
      id: Date.now().toString(),
      name: uploadName,
      category: uploadCategory,
      price: parseFloat(uploadPrice),
      image: uploadPreview,
      description: "",
      isAvailable: true,
    };

    const updatedDishes = [...dishes, newDish];
    const result = saveDishes(updatedDishes);

    if (result.success) {
      setDishes(updatedDishes);
      setUploadName("");
      setUploadPrice("");
      setUploadImage(null);
      setUploadPreview("");
      setShowUploadDialog(false);
    } else {
      alert(result.message || "添加失败，请重试");
    }
  };

  // 分类标签组件
  const CategoryTab = ({ category, label, color }: { category: DishCategory; label: string; color: string }) => (
    <button
      onClick={() => setSelectedCategory(category)}
      className={`
        px-3 py-1.5 rounded-lg font-medium transition-all duration-200 text-sm
        ${selectedCategory === category
          ? `${color} text-white shadow-md`
          : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
        }
      `}
    >
      {label}
    </button>
  );

  return (
    <div className="min-h-screen bg-gradient-to-br from-red-50 via-orange-50 to-yellow-50">
      {/* 装饰背景 */}
      <div className="fixed inset-0 chinese-pattern pointer-events-none" />

      {/* 顶部信息栏 */}
      <header className={`sticky top-0 z-40 bg-white/90 backdrop-blur-md shadow-sm border-b-2 border-red-200 transition-all duration-300 ${isFullscreen ? 'py-1.5' : 'py-2'}`}>
        <div className="container mx-auto px-3 py-2">
          <div className="flex items-center justify-between">
            {/* 餐厅名称 */}
            <div className="flex items-center gap-2">
              <div className="w-10 h-10 rounded-full bg-gradient-to-br from-red-500 to-orange-500 flex items-center justify-center text-white font-bold text-lg shadow-lg">
                陶
              </div>
              <div>
                <h1 className="text-xl font-bold chinese-title">陶然小灶</h1>
                <p className="text-[10px] text-gray-500">中华美食 · 传统味道</p>
              </div>
            </div>

            {/* 桌号和人数 */}
            <div className="flex items-center gap-3">
              <div className="flex items-center gap-1.5 px-3 py-1.5 bg-orange-50 rounded-lg border border-orange-200">
                <Table className="w-4 h-4 text-orange-600" />
                <Select value={tableNumber} onValueChange={setTableNumber}>
                  <SelectTrigger className="w-24 border-0 bg-transparent text-sm h-8">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    {DEFAULT_TABLES.map(table => (
                      <SelectItem key={table.value} value={table.value}>
                        {table.label}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>

              <div className="flex items-center gap-1.5 px-3 py-1.5 bg-red-50 rounded-lg border border-red-200">
                <Users className="w-4 h-4 text-red-600" />
                <Select value={customerCount} onValueChange={setCustomerCount}>
                  <SelectTrigger className="w-20 border-0 bg-transparent text-sm h-8">
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    {DEFAULT_PEOPLE.map(people => (
                      <SelectItem key={people.value} value={people.value}>
                        {people.label}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
            </div>

            {/* 管理按钮 */}
            <Button
              size="sm"
              variant={isEditMode ? "default" : "outline"}
              className={`${isEditMode ? 'bg-gradient-to-r from-purple-600 to-blue-500 hover:from-purple-700 hover:to-blue-600' : 'border-2 border-purple-400 text-purple-600 hover:bg-purple-50'} shadow-md mr-1.5 h-9`}
              onClick={() => setIsEditMode(!isEditMode)}
            >
              {isEditMode ? (
                <Eye className="w-4 h-4 mr-1" />
              ) : (
                <Settings className="w-4 h-4 mr-1" />
              )}
              {isEditMode ? '查看' : '管理'}
            </Button>

            {/* 全屏切换按钮 */}
            <Button
              size="sm"
              variant={isFullscreen ? "default" : "outline"}
              className={`${isFullscreen ? 'bg-gradient-to-r from-green-600 to-teal-500 hover:from-green-700 hover:to-teal-600' : 'border-2 border-green-400 text-green-600 hover:bg-green-50'} shadow-md mr-1.5 h-9`}
              onClick={toggleFullscreen}
              title={isFullscreen ? "退出全屏" : "进入全屏"}
            >
              {isFullscreen ? (
                <Minimize2 className="w-4 h-4" />
              ) : (
                <Maximize2 className="w-4 h-4" />
              )}
            </Button>

            {/* 打印机设置按钮 */}
            <Button
              size="sm"
              variant="outline"
              className="border-2 border-blue-400 text-blue-600 hover:bg-blue-50 shadow-md mr-1.5 h-9"
              onClick={() => setShowPrinterSettings(true)}
              title="打印机设置"
            >
              <PrinterIcon className="w-4 h-4" />
            </Button>

            {/* 购物车按钮 */}
            <Sheet open={isCartOpen} onOpenChange={setIsCartOpen}>
              <SheetTrigger asChild>
                <Button
                  size="sm"
                  className="bg-gradient-to-r from-red-600 to-orange-500 hover:from-red-700 hover:to-orange-600 text-white shadow-md relative h-9"
                >
                  <ShoppingCart className="w-4 h-4 mr-1" />
                  购物车
                  {cartCount > 0 && (
                    <span className="absolute -top-1.5 -right-1.5 bg-white text-red-600 rounded-full w-5 h-5 flex items-center justify-center text-xs font-bold shadow">
                      {cartCount}
                    </span>
                  )}
                </Button>
              </SheetTrigger>
              <SheetContent className="w-[400px]">
                <SheetHeader>
                  <SheetTitle className="chinese-title text-2xl">购物车</SheetTitle>
                </SheetHeader>
                <Separator className="my-4" />
                {cart.length === 0 ? (
                  <div className="flex flex-col items-center justify-center h-64 text-gray-400">
                    <ShoppingCart className="w-16 h-16 mb-4" />
                    <p>购物车是空的</p>
                  </div>
                ) : (
                  <ScrollArea className="h-[calc(100vh-200px)]">
                    <div className="space-y-4 pr-4">
                      {cart.map(item => (
                        <Card key={item.id} className="p-4 hover:shadow-md transition-shadow">
                          <div className="flex items-start gap-4">
                            <div className="relative w-20 h-20 rounded-lg overflow-hidden flex-shrink-0 border border-gray-200">
                              <img
                                src={item.image}
                                alt={item.name}
                                className="w-full h-full object-cover"
                              />
                            </div>
                            <div className="flex-1 min-w-0">
                              <h3 className="font-semibold text-lg mb-1 truncate">{item.name}</h3>
                              <p className="text-red-600 font-bold mb-2">¥{item.price}</p>
                              {item.taste && item.taste.length > 0 && (
                                <p className="text-sm text-orange-600 mb-1">
                                  口味：{item.taste.join("、")}
                                </p>
                              )}
                              {item.avoidance && item.avoidance.length > 0 && (
                                <p className="text-sm text-orange-600 mb-1">
                                  忌口：{item.avoidance.join("、")}
                                </p>
                              )}
                              {item.customTaste && (
                                <p className="text-sm text-gray-600 mb-1">
                                  备注：{item.customTaste}
                                </p>
                              )}
                              <div className="flex items-center gap-2 mt-2">
                                <Button
                                  size="sm"
                                  variant="outline"
                                  onClick={() => updateQuantity(item.id, -1)}
                                >
                                  <Minus className="w-4 h-4" />
                                </Button>
                                <span className="w-12 text-center font-semibold">{item.quantity}</span>
                                <Button size="sm" variant="outline" onClick={() => updateQuantity(item.id, 1)}>
                                  <Plus className="w-4 h-4" />
                                </Button>
                                <Button
                                  size="sm"
                                  variant="ghost"
                                  className="ml-auto text-red-500 hover:text-red-700 hover:bg-red-50"
                                  onClick={() => removeFromCart(item.id)}
                                >
                                  <Trash2 className="w-4 h-4" />
                                </Button>
                              </div>
                            </div>
                          </div>
                        </Card>
                      ))}
                    </div>
                  </ScrollArea>
                )}
                <div className="mt-4 space-y-3">
                  <Separator />
                  <div className="flex items-center justify-between text-lg">
                    <span className="text-gray-600">小计</span>
                    <span className="font-bold text-red-600">¥{cartTotal}</span>
                  </div>
                  <div className="flex gap-2">
                    <Dialog open={showPrintDialog} onOpenChange={setShowPrintDialog}>
                      <DialogTrigger asChild>
                        <Button
                          className="flex-1 bg-gradient-to-r from-red-600 to-orange-500 hover:from-red-700 hover:to-orange-600 text-white"
                          disabled={cart.length === 0}
                        >
                          <Printer className="w-4 h-4 mr-2" />
                          确认打印
                        </Button>
                      </DialogTrigger>
                      <DialogContent>
                        <DialogHeader>
                          <DialogTitle className="chinese-title text-2xl">确认订单</DialogTitle>
                        </DialogHeader>
                        <div className="space-y-4">
                          <div className="p-4 bg-gray-50 rounded-lg">
                            <div className="flex justify-between mb-2">
                              <span>桌号：</span>
                              <span className="font-semibold">{tableNumber}</span>
                            </div>
                            <div className="flex justify-between">
                              <span>人数：</span>
                              <span className="font-semibold">{customerCount}</span>
                            </div>
                          </div>
                          <ScrollArea className="h-64">
                            {cart.map(item => (
                              <div key={item.id} className="py-2 border-b">
                                <div className="flex justify-between">
                                  <span className="font-semibold">{item.name} x{item.quantity}</span>
                                  <span className="font-semibold text-red-600">¥{item.price * item.quantity}</span>
                                </div>
                                {(item.taste?.length || item.avoidance?.length || item.customTaste) && (
                                  <div className="text-sm text-gray-600 mt-1 ml-4">
                                    {item.taste && item.taste.length > 0 && (
                                      <span>口味：{item.taste.join("、")}</span>
                                    )}
                                    {item.avoidance && item.avoidance.length > 0 && (
                                      <span className="ml-2">忌口：{item.avoidance.join("、")}</span>
                                    )}
                                    {item.customTaste && (
                                      <span className="ml-2">备注：{item.customTaste}</span>
                                    )}
                                  </div>
                                )}
                              </div>
                            ))}
                          </ScrollArea>
                          <div className="flex justify-between text-xl font-bold">
                            <span>合计：</span>
                            <span className="text-red-600">¥{cartTotal}</span>
                          </div>
                        </div>
                        <DialogFooter>
                          <Button variant="outline" onClick={() => setShowPrintDialog(false)}>
                            取消
                          </Button>
                          <Button onClick={handlePrint} className="bg-gradient-to-r from-red-600 to-orange-500 text-white">
                            <Check className="w-4 h-4 mr-2" />
                            确认打印
                          </Button>
                        </DialogFooter>
                      </DialogContent>
                    </Dialog>
                    <Button
                      variant="outline"
                      className="flex-1"
                      onClick={clearCart}
                      disabled={cart.length === 0}
                    >
                      清空
                    </Button>
                  </div>
                </div>
              </SheetContent>
            </Sheet>
          </div>
        </div>
      </header>

      {/* 分类导航 */}
      <div className={`container mx-auto px-3 transition-all duration-300 ${isFullscreen ? 'py-1.5' : 'py-2'}`}>
        <div className={`flex flex-wrap gap-2 ${isFullscreen ? 'mb-2' : 'mb-3'}`}>
          {(Object.keys(CATEGORY_NAMES) as DishCategory[]).map(category => (
            <CategoryTab
              key={category}
              category={category}
              label={CATEGORY_NAMES[category]}
              color={CATEGORY_COLORS[category]}
            />
          ))}
        </div>

        {/* 管理工具栏 */}
        {isEditMode && (
          <div className="mb-3 p-3 bg-purple-50 border-2 border-purple-200 rounded-lg">
            <div className="flex items-center justify-between flex-wrap gap-2">
              <div className="flex items-center gap-2">
                <AlertCircle className="w-5 h-5 text-purple-600" />
                <span className="text-sm text-purple-700">管理模式：点击菜品可编辑图片和信息</span>
              </div>
              <div className="flex gap-2">
                <Button
                  size="sm"
                  variant="outline"
                  className="border-2 border-orange-400 text-orange-600 hover:bg-orange-50"
                  onClick={handleOptimizeStorage}
                >
                  <Download className="w-4 h-4 mr-1" />
                  优化存储
                </Button>
                <Button
                  size="sm"
                  variant="outline"
                  className="border-2 border-purple-400 text-purple-600 hover:bg-purple-50"
                  onClick={() => setShowAvoidanceManagement(true)}
                >
                  <Settings className="w-4 h-4 mr-1" />
                  忌口标签
                </Button>
              </div>
            </div>
          </div>
        )}

        {/* 菜品网格 */}
        <div className={`grid grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 ${isFullscreen ? 'lg:grid-cols-6 xl:grid-cols-7' : ''}`}>
          {filteredDishes.map(dish => {
            const itemCount = getCartItemCount(dish.id);
            const tasteInfo = tasteSelections[dish.id] || { tags: [], custom: "" };
            const hasTasteSelection = tasteInfo.tags.length > 0 || tasteInfo.custom;

            return (
              <Card
                key={dish.id}
                className="overflow-hidden hover:shadow-xl transition-all duration-300 border-2 hover:border-red-300"
              >
                {/* 图片区域 - 可点击编辑或查看 */}
                <div
                  className="relative aspect-[4/3] overflow-hidden cursor-pointer"
                  onClick={() => handleDishClick(dish)}
                >
                  <img
                    src={dish.image}
                    alt={dish.name}
                    className="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  />
                  {dish.isAvailable && (
                    <Badge className="absolute top-1 right-1 bg-red-500 text-white text-xs px-2 py-0.5">
                      在售
                    </Badge>
                  )}
                  {/* 管理模式编辑提示 */}
                  {isEditMode && (
                    <div className="absolute bottom-1 left-1 bg-black/50 text-white text-[10px] px-1.5 py-0.5 rounded">
                      点击编辑
                    </div>
                  )}
                  {/* 查看模式图片数量提示 */}
                  {!isEditMode && dish.images && dish.images.length > 1 && (
                    <div className="absolute bottom-1 right-1 bg-black/50 text-white text-[10px] px-1.5 py-0.5 rounded">
                      <ImageIcon className="w-3 h-3 inline mr-0.5" />
                      {dish.images.length}张
                    </div>
                  )}
                </div>

                <div className="p-2">
                  {/* 菜品名称 - 点击选择口味 */}
                  <div
                    className="mb-1 cursor-pointer hover:text-red-600 transition-colors"
                    onClick={() => {
                      // 打开口味选择的临时对话框（简化版）
                      const tags = prompt(
                        `请选择口味（用逗号分隔）\n可用：${TASTE_TAGS.join("、")}`,
                        tasteInfo.tags.join("、")
                      );
                      if (tags !== null) {
                        handleCustomTasteChange(dish.id, tags);
                      }
                    }}
                  >
                    <h3 className="font-bold text-sm truncate">{dish.name}</h3>
                    {hasTasteSelection && (
                      <div className="text-[10px] text-orange-600 mt-0.5">
                        {tasteInfo.tags.join("、")}{tasteInfo.custom ? `、${tasteInfo.custom}` : ""}
                      </div>
                    )}
                  </div>

                  {dish.description && (
                    <p className="text-[10px] text-gray-500 mb-1 line-clamp-1">{dish.description}</p>
                  )}
                  <div className="flex items-center justify-between gap-1">
                    <span className="text-red-600 font-bold text-base">¥{dish.price}</span>

                    {/* 忌口按钮 - 仅当该分类有标签时显示 */}
                    {avoidanceTagsByCategory[dish.category]?.length > 0 && (
                      <Button
                        size="sm"
                        variant="outline"
                        onClick={() => openAvoidanceDialog(dish)}
                        className={`h-7 px-2 text-[10px] ${
                          avoidanceSelections[dish.id]?.length > 0
                            ? 'bg-orange-100 border-orange-300 text-orange-700'
                            : 'border-gray-300 text-gray-600'
                        }`}
                        title={dish.category === 'beverage' ? "选择温度" : "选择忌口"}
                      >
                        {avoidanceSelections[dish.id]?.length > 0
                          ? `${dish.category === 'beverage' ? '温度' : '忌口'}(${avoidanceSelections[dish.id].length})`
                          : (dish.category === 'beverage' ? '温度' : '忌口')}
                      </Button>
                    )}

                    {/* 数量控制按钮 */}
                    <div className="flex items-center gap-1">
                      {itemCount === 0 ? (
                        <Button
                          size="sm"
                          onClick={() => addToCart(dish)}
                          className="bg-gradient-to-r from-red-600 to-orange-500 hover:from-red-700 hover:to-orange-600 text-white h-7 px-3 text-xs"
                        >
                          <Plus className="w-3 h-3" />
                        </Button>
                      ) : (
                        <div className="flex items-center gap-0.5">
                          <Button
                            size="sm"
                            variant="outline"
                            onClick={() => updateQuantity(dish.id, -1)}
                            className="h-7 w-7 text-xs"
                          >
                            <Minus className="w-3 h-3" />
                          </Button>
                          <div className="bg-gradient-to-r from-orange-100 to-red-100 px-1.5 py-0.5 rounded min-w-[50px] text-center">
                            <span className="text-sm font-bold text-red-600">{itemCount}</span>
                            <span className="text-[10px] text-gray-600 ml-0.5">份</span>
                          </div>
                          <Button
                            size="sm"
                            onClick={() => addToCart(dish)}
                            className="bg-gradient-to-r from-red-600 to-orange-500 hover:from-red-700 hover:to-orange-600 text-white h-7 w-7 text-xs"
                          >
                            <Plus className="w-3 h-3" />
                          </Button>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </Card>
            );
          })}
        </div>
      </div>

      {/* 上传菜品按钮 */}
      <Dialog open={showUploadDialog} onOpenChange={setShowUploadDialog}>
        <DialogTrigger asChild>
          <Button
            size="lg"
            className="fixed bottom-6 right-6 w-14 h-14 rounded-full bg-gradient-to-r from-red-600 to-orange-500 hover:from-red-700 hover:to-orange-600 text-white shadow-xl z-50"
          >
            <Camera className="w-6 h-6" />
          </Button>
        </DialogTrigger>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="chinese-title text-2xl">上传菜品</DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <label className="block text-sm font-medium mb-2">菜品图片</label>
              <div className="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-red-400 transition-colors">
                {uploadPreview ? (
                  <div className="relative">
                    <img
                      src={uploadPreview}
                      alt="Preview"
                      className="w-full h-48 object-cover rounded-lg mb-2"
                    />
                    <Button
                      variant="ghost"
                      size="sm"
                      onClick={() => {
                        setUploadPreview("");
                        setUploadImage(null);
                      }}
                      className="absolute top-2 right-2"
                    >
                      <X className="w-4 h-4" />
                    </Button>
                  </div>
                ) : (
                  <div>
                    <Upload className="w-12 h-12 mx-auto text-gray-400 mb-2" />
                    <p className="text-sm text-gray-500 mb-2">点击上传或拖拽图片</p>
                    <input
                      type="file"
                      accept="image/png, image/jpeg, image/jpg, image/webp, image/gif"
                      onChange={handleImageChange}
                      className="hidden"
                      id="dish-image"
                    />
                    <label
                      htmlFor="dish-image"
                      className="inline-block px-4 py-2 bg-red-100 text-red-600 rounded-lg cursor-pointer hover:bg-red-200 transition-colors"
                    >
                      选择图片
                    </label>
                  </div>
                )}
              </div>
            </div>

            <div>
              <label className="block text-sm font-medium mb-2">菜品名称</label>
              <Input
                placeholder="请输入菜品名称"
                value={uploadName}
                onChange={(e) => setUploadName(e.target.value)}
              />
            </div>

            <div>
              <label className="block text-sm font-medium mb-2">价格</label>
              <Input
                type="number"
                placeholder="请输入价格"
                value={uploadPrice}
                onChange={(e) => setUploadPrice(e.target.value)}
              />
            </div>

            <div>
              <label className="block text-sm font-medium mb-2">分类</label>
              <Select value={uploadCategory} onValueChange={(value: DishCategory) => setUploadCategory(value)}>
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  {(Object.keys(CATEGORY_NAMES) as DishCategory[]).map(category => (
                    <SelectItem key={category} value={category}>
                      {CATEGORY_NAMES[category]}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
          </div>
          <DialogFooter className="mt-6">
            <Button variant="outline" onClick={() => setShowUploadDialog(false)}>
              取消
            </Button>
            <Button onClick={handleAddDish} className="bg-gradient-to-r from-red-600 to-orange-500 text-white">
              添加菜品
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 打印内容（隐藏） */}
      <div id="print-content" className="hidden print:block">
        <div className="header">
          <h1>陶然小灶</h1>
          <p>点菜清单</p>
        </div>
        <div className="info-row">
          <span>桌号：{tableNumber}</span>
          <span>人数：{customerCount}</span>
        </div>
        <div className="info-row">
          <span>时间：{currentTime}</span>
        </div>
        <div className="mt-6">
          {cart.map(item => (
            <div key={item.id} className="item-row">
              <div className="flex-1">
                <div className="item-name">
                  {item.name}
                  <span className="item-qty"> x{item.quantity}</span>
                </div>
                {(item.taste && item.taste.length > 0) || item.customTaste ? (
                  <div className="item-taste">
                    口味: {item.taste?.join("、") || ""}{item.customTaste ? `、${item.customTaste}` : ""}
                  </div>
                ) : null}
              </div>
              <div>¥{item.price * item.quantity}</div>
            </div>
          ))}
        </div>
        <div className="total-section">
          <span>合计：¥{cartTotal}</span>
        </div>
        <div className="footer">
          <p>感谢您的光临！</p>
          <p>陶然小灶 · 中华美食</p>
        </div>
      </div>

      {/* 菜品编辑对话框 */}
      <Dialog open={editDishDialog} onOpenChange={setEditDishDialog}>
        <DialogContent className="max-w-2xl max-h-[90vh] overflow-y-auto">
          <DialogHeader>
            <DialogTitle className="chinese-title text-2xl">编辑菜品</DialogTitle>
          </DialogHeader>
          {editingDish && (
            <div className="space-y-4">
              <div>
                <Label className="text-base">菜品图片（支持多张）</Label>
                <div className="space-y-3 mt-2">
                  {/* 已上传的图片列表 */}
                  {editImages.length > 0 && (
                    <div className="grid grid-cols-3 gap-2">
                      {editImages.map((img, index) => (
                        <div key={index} className="relative aspect-video rounded-lg overflow-hidden border-2 border-gray-200">
                          <img src={img} alt={`菜品图片${index + 1}`} className="w-full h-full object-cover" />
                          <Button
                            variant="destructive"
                            size="icon"
                            className="absolute top-1 right-1 w-6 h-6"
                            onClick={() => removeImageFromEdit(index)}
                          >
                            <X className="w-3 h-3" />
                          </Button>
                          <div className="absolute bottom-1 left-1 bg-black/50 text-white text-xs px-1 rounded">
                            {index + 1}
                          </div>
                        </div>
                      ))}
                      {/* 添加新图片按钮 */}
                      {editImages.length < 6 && (
                        <label className="relative aspect-video border-2 border-dashed border-gray-300 rounded-lg flex flex-col items-center justify-center cursor-pointer hover:border-red-400 transition-colors bg-gray-50">
                          <Upload className="w-8 h-8 text-gray-400 mb-1" />
                          <span className="text-sm text-gray-500">添加图片</span>
                          <input
                            type="file"
                            accept="image/png, image/jpeg, image/jpg, image/webp, image/gif"
                            onChange={(e) => {
                              const file = e.target.files?.[0];
                              if (file) addImageToEdit(file);
                            }}
                            className="hidden"
                          />
                        </label>
                      )}
                    </div>
                  )}

                  {/* 如果没有图片，显示上传区域 */}
                  {editImages.length === 0 && (
                    <div className="border-2 border-dashed border-gray-300 rounded-lg p-8 hover:border-red-400 transition-colors bg-gray-50">
                      <Upload className="w-16 h-16 mx-auto text-gray-400 mb-3" />
                      <p className="text-center text-sm text-gray-500 mb-3">
                        点击上传或拖拽图片<br />支持最多6张图片
                      </p>
                      <input
                        type="file"
                        accept="image/png, image/jpeg, image/jpg, image/webp, image/gif"
                        onChange={handleEditImageChange}
                        className="hidden"
                        id="edit-dish-image"
                      />
                      <label
                        htmlFor="edit-dish-image"
                        className="inline-block px-6 py-3 bg-red-100 text-red-600 rounded-lg cursor-pointer hover:bg-red-200 transition-colors"
                      >
                        选择图片
                      </label>
                    </div>
                  )}
                </div>
              </div>

              <div>
                <Label htmlFor="edit-name" className="text-base">菜品名称</Label>
                <Input
                  id="edit-name"
                  value={editingDish.name}
                  onChange={(e) => setEditingDish({ ...editingDish, name: e.target.value })}
                  className="text-lg"
                />
              </div>

              <div>
                <Label htmlFor="edit-price" className="text-base">价格</Label>
                <Input
                  id="edit-price"
                  type="number"
                  value={editingDish.price}
                  onChange={(e) => setEditingDish({ ...editingDish, price: parseFloat(e.target.value) || 0 })}
                  className="text-lg"
                />
              </div>

              <div>
                <Label htmlFor="edit-category" className="text-base">分类</Label>
                <Select
                  value={editingDish.category}
                  onValueChange={(value: DishCategory) => setEditingDish({ ...editingDish, category: value })}
                >
                  <SelectTrigger>
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    {(Object.keys(CATEGORY_NAMES) as DishCategory[]).map(category => (
                      <SelectItem key={category} value={category}>
                        {CATEGORY_NAMES[category]}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
            </div>
          )}
          <DialogFooter className="mt-6">
            <DialogClose asChild>
              <Button variant="outline">取消</Button>
            </DialogClose>
            <Button onClick={saveDishEdit} className="bg-gradient-to-r from-red-600 to-orange-500 text-white text-lg">
              <Check className="w-5 h-5 mr-2" />
              保存
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 菜品查看详情对话框 */}
      <Dialog open={viewDishDialog} onOpenChange={setViewDishDialog}>
        <DialogContent className="max-w-2xl">
          <DialogHeader>
            <DialogTitle className="chinese-title text-3xl">{viewingDish?.name}</DialogTitle>
          </DialogHeader>
          {viewingDish && (
            <div className="space-y-4">
              {/* 图片展示区域 */}
              <div className="relative bg-gray-100 rounded-lg overflow-hidden">
                <div className="aspect-video">
                  <img
                    src={(viewingDish.images || [viewingDish.image])[currentImageIndex]}
                    alt={viewingDish.name}
                    className="w-full h-full object-contain"
                  />
                </div>

                {/* 图片导航按钮 */}
                {(viewingDish.images && viewingDish.images.length > 1) || (
                  viewingDish.images && viewingDish.images.length > 0 ? false : false
                ) ? (
                  <>
                    <Button
                      size="icon"
                      variant="ghost"
                      className="absolute left-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white"
                      onClick={() => setCurrentImageIndex((viewingDish.images?.length || 1) - 1 === currentImageIndex ? 0 : currentImageIndex - 1)}
                      disabled={(viewingDish.images?.length || 1) <= 1}
                    >
                      <ChevronLeft className="w-6 h-6" />
                    </Button>
                    <Button
                      size="icon"
                      variant="ghost"
                      className="absolute right-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white"
                      onClick={() => setCurrentImageIndex(currentImageIndex + 1 >= (viewingDish.images?.length || 1) ? 0 : currentImageIndex + 1)}
                      disabled={(viewingDish.images?.length || 1) <= 1}
                    >
                      <ChevronRight className="w-6 h-6" />
                    </Button>

                    {/* 图片指示器 */}
                    <div className="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                      {(viewingDish.images || [viewingDish.image]).map((_, index) => (
                        <div
                          key={index}
                          className={`w-2 h-2 rounded-full transition-all ${
                            index === currentImageIndex ? 'bg-white w-4' : 'bg-white/50'
                          }`}
                        />
                      ))}
                    </div>
                  </>
                ) : null}
              </div>

              {/* 菜品信息 */}
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <span className="text-3xl font-bold text-red-600">¥{viewingDish.price}</span>
                  <Badge className={CATEGORY_COLORS[viewingDish.category] + " text-white text-base px-4 py-2"}>
                    {CATEGORY_NAMES[viewingDish.category]}
                  </Badge>
                </div>
                {viewingDish.description && (
                  <p className="text-gray-600 text-lg">{viewingDish.description}</p>
                )}
              </div>
            </div>
          )}
          <DialogFooter className="mt-6">
            <DialogClose asChild>
              <Button variant="outline" className="text-lg px-6 py-6">关闭</Button>
            </DialogClose>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 备份提示对话框 */}
      <Dialog open={showBackupAlert} onOpenChange={setShowBackupAlert}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2 text-2xl">
              <AlertCircle className="w-6 h-6 text-orange-500" />
              数据备份提示
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <p className="text-base">距离上次数据备份已超过一周，建议您现在备份菜品数据到本地。</p>
            <div className="bg-orange-50 p-4 rounded-lg">
              <p className="text-sm text-gray-600">备份内容包括：</p>
              <ul className="text-sm text-gray-600 mt-2 list-disc list-inside">
                <li>所有菜品信息（名称、价格、分类、图片）</li>
                <li>历史订单记录</li>
              </ul>
            </div>
          </div>
          <DialogFooter className="mt-6">
            <DialogClose asChild>
              <Button variant="outline">稍后提醒</Button>
            </DialogClose>
            <Button onClick={handleExportBackup} className="bg-gradient-to-r from-red-600 to-orange-500 text-white text-lg">
              <Download className="w-5 h-5 mr-2" />
              立即备份
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 打印机设置对话框 */}
      <Dialog open={showPrinterSettings} onOpenChange={setShowPrinterSettings}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2 text-2xl">
              <PrinterIcon className="w-6 h-6 text-blue-600" />
              打印机设置
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <Label className="text-base font-medium">打印机IP地址</Label>
              <Input
                type="text"
                placeholder="例如: 192.168.1.100"
                value={printerIP}
                onChange={(e) => setPrinterIP(e.target.value)}
                className="mt-2 text-lg"
              />
            </div>
            <div className="bg-blue-50 p-4 rounded-lg">
              <p className="text-sm text-gray-600 font-medium mb-2">使用说明：</p>
              <ul className="text-sm text-gray-600 space-y-1">
                <li>• 确保打印机和iPad连接同一WiFi网络</li>
                <li>• 在打印机上查看或设置IP地址</li>
                <li>• 输入完整的IP地址（如 192.168.1.100）</li>
                <li>• HP LaserJet MFP M232dw 默认端口: 9100</li>
              </ul>
            </div>
          </div>
          <DialogFooter className="mt-6 gap-2">
            <Button
              variant="outline"
              onClick={handleTestPrint}
              disabled={!printerIP}
              className="flex-1"
            >
              <PrinterIcon className="w-4 h-4 mr-2" />
              测试打印
            </Button>
            <DialogClose asChild>
              <Button variant="outline" className="flex-1">取消</Button>
            </DialogClose>
            <Button
              onClick={() => {
                savePrinterIP(printerIP);
                setShowPrinterSettings(false);
                alert("打印机IP保存成功！");
              }}
              className="bg-gradient-to-r from-blue-600 to-teal-500 text-white text-lg flex-1"
            >
              保存设置
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 忌口选择对话框 */}
      <Dialog open={showAvoidanceDialog} onOpenChange={setShowAvoidanceDialog}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2 text-2xl">
              <AlertCircle className="w-6 h-6 text-orange-600" />
              忌口选择
            </DialogTitle>
          </DialogHeader>
          {currentAvoidanceDish && (
            <div className="space-y-4">
              <div className="bg-orange-50 p-3 rounded-lg">
                <p className="text-sm font-medium text-gray-700">菜品：{currentAvoidanceDish.name}</p>
                <p className="text-xs text-gray-500 mt-1">分类：{CATEGORY_NAMES[currentAvoidanceDish.category]}</p>
              </div>
              <div>
                <Label className="text-base font-medium mb-3 block">请选择选项：</Label>
                {avoidanceTagsByCategory[currentAvoidanceDish.category]?.length === 0 ? (
                  <div className="text-center py-8 text-gray-500">
                    <p>该分类暂无可选选项</p>
                  </div>
                ) : (
                  <div className="flex flex-wrap gap-2">
                    {avoidanceTagsByCategory[currentAvoidanceDish.category]?.map((tag) => {
                      const isSelected = avoidanceSelections[currentAvoidanceDish.id]?.includes(tag.name);
                      return (
                        <Badge
                          key={tag.id}
                          variant={isSelected ? "default" : "outline"}
                          className={`
                            cursor-pointer px-4 py-2 text-base flex items-center gap-1
                            ${isSelected
                              ? 'bg-orange-600 hover:bg-orange-700 text-white'
                              : 'hover:bg-orange-100 text-gray-700 border-2'
                            }
                          `}
                          onClick={() => toggleAvoidanceTag(tag.name)}
                        >
                          {tag.icon && <span>{tag.icon}</span>}
                          {isSelected && <Check className="w-4 h-4" />}
                          {tag.name}
                        </Badge>
                      );
                    })}
                  </div>
                )}
              </div>
              {avoidanceSelections[currentAvoidanceDish.id]?.length > 0 && (
                <div className="bg-blue-50 p-3 rounded-lg">
                  <p className="text-sm text-gray-700">
                    已选：<span className="font-semibold text-orange-700">
                      {avoidanceSelections[currentAvoidanceDish.id].join("、")}
                    </span>
                  </p>
                </div>
              )}
            </div>
          )}
          <DialogFooter className="mt-6">
            <DialogClose asChild>
              <Button variant="outline" className="text-lg">取消</Button>
            </DialogClose>
            <Button
              onClick={() => setShowAvoidanceDialog(false)}
              className="bg-gradient-to-r from-orange-600 to-red-500 text-white text-lg"
            >
              确定
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 忌口标签管理对话框 */}
      <Dialog open={showAvoidanceManagement} onOpenChange={setShowAvoidanceManagement}>
        <DialogContent className="max-w-2xl">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2 text-2xl">
              <Settings className="w-6 h-6 text-purple-600" />
              标签管理
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            {/* 分类选择 */}
            <div>
              <Label className="text-base font-medium mb-2 block">选择分类：</Label>
              <div className="flex flex-wrap gap-2">
                {(Object.keys(CATEGORY_NAMES) as DishCategory[]).map((category) => (
                  <button
                    key={category}
                    onClick={() => setManagingCategory(category)}
                    className={`
                      px-4 py-2 rounded-lg font-medium transition-all
                      ${managingCategory === category
                        ? `${CATEGORY_COLORS[category]} text-white shadow-md`
                        : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
                      }
                    `}
                  >
                    {CATEGORY_NAMES[category]}
                  </button>
                ))}
              </div>
            </div>

            {/* 添加新标签 */}
            <div className="flex gap-2">
              <Input
                placeholder="输入标签名称（如：不吃香菜）"
                value={newAvoidanceTagName}
                onChange={(e) => setNewAvoidanceTagName(e.target.value)}
                onKeyPress={(e) => {
                  if (e.key === 'Enter') {
                    e.preventDefault();
                    handleAddAvoidanceTag();
                  }
                }}
                className="flex-1"
              />
              <Input
                placeholder="图标emoji（可选，如：🚫）"
                value={newAvoidanceTagIcon}
                onChange={(e) => setNewAvoidanceTagIcon(e.target.value)}
                className="w-32"
              />
              <Button
                onClick={handleAddAvoidanceTag}
                className="bg-gradient-to-r from-green-600 to-teal-500 text-white"
              >
                <Plus className="w-4 h-4 mr-1" />
                添加
              </Button>
            </div>

            {/* 标签列表 */}
            <div>
              <Label className="text-base font-medium mb-3 block">
                {CATEGORY_NAMES[managingCategory]}标签（{avoidanceTagsByCategory[managingCategory]?.length || 0}个）：
              </Label>
              <div className="flex flex-wrap gap-2 max-h-[300px] overflow-y-auto p-3 bg-gray-50 rounded-lg">
                {(avoidanceTagsByCategory[managingCategory] || []).length === 0 ? (
                  <p className="text-sm text-gray-500 w-full text-center py-4">
                    该分类暂无标签，{managingCategory !== 'alcohol' ? '请添加' : '酒水类不需要标签'}
                  </p>
                ) : (
                  (avoidanceTagsByCategory[managingCategory] || []).map((tag) => (
                    <Badge
                      key={tag.id}
                      variant="outline"
                      className="px-4 py-2 text-base flex items-center gap-2 hover:bg-red-50 hover:border-red-300 transition-colors"
                    >
                      {tag.icon && <span>{tag.icon}</span>}
                      {tag.name}
                      <X
                        className="w-4 h-4 cursor-pointer text-gray-500 hover:text-red-600"
                        onClick={() => handleDeleteAvoidanceTag(tag.id)}
                      />
                    </Badge>
                  ))
                )}
              </div>
            </div>

            {/* 使用说明 */}
            <div className="bg-purple-50 p-4 rounded-lg">
              <p className="text-sm text-gray-600 font-medium mb-2">使用说明：</p>
              <ul className="text-sm text-gray-600 space-y-1 list-disc list-inside">
                <li>选择不同的菜品分类来管理该分类的标签</li>
                <li>饮料类标签用于温度选择（如：加冰、常温）</li>
                <li>酒水类不需要标签，请留空</li>
                <li>用户点菜时会看到对应分类的标签</li>
                <li>标签信息会显示在购物车和订单中</li>
              </ul>
            </div>
          </div>
          <DialogFooter className="mt-6">
            <DialogClose asChild>
              <Button variant="outline" className="text-lg">关闭</Button>
            </DialogClose>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}
